# System Atlas environment variables (all optional; defaults shown).
# Copy to .env if you need to override.

# Port for the Vite dev server (web client).
SYSTEM_ATLAS_WEB_PORT=5173

# Port for the Express API server.
SYSTEM_ATLAS_API_PORT=5174

# Absolute path of a project to open on startup. Without it, the server starts
# with the last-used workspace from the per-machine registry (or none).
# SYSTEM_ATLAS_WORKSPACE=C:/Dev/Projects/your-project
